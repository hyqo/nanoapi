{
    "name": "@hyqo/nanoapi",
    "version": "0.0.0-dev",
    "repository": {
        "type": "git",
        "url": "https://github.com/hyqo/nanoapi"
    },
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "files": [
        "dist",
        "!dist/**/*.test.*",
        "!dist/**/*.spec.*"
    ],
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "format": "prettier --write .",
        "lint": "prettier --check . && eslint .",
        "test:unit": "vitest",
        "test": "npm run test:unit -- --run"
    },
    "packageManager": "yarn@4.15.0",
    "devDependencies": {
        "@eslint/compat": "^1.4.0",
        "@eslint/js": "^9.39.1",
        "@types/node": "^24",
        "eslint": "^9.39.1",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^16.5.0",
        "prettier": "^3.7.4",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.48.1",
        "vitest": "^4.0.15"
    }
}
